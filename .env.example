# ── Required ──────────────────────────────────────────────────────────────────
PRIVATE_KEY=0x...
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
BUILDER_API_KEY=
BUILDER_SECRET=
BUILDER_PASSPHRASE=

# ── Operational ───────────────────────────────────────────────────────────────
DRY_RUN=true
USE_RELAYER=true

# ── Storage ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://user:password@localhost:5432/polymarket_bot

# ── Fallback state (minimal deployments only) ─────────────────────────────────
STATE_FILE_PATH=./state.json.enc
STATE_ENCRYPTION_KEY=

# ── Strategy enablement ───────────────────────────────────────────────────────
STRATEGY_A_ENABLED=true
STRATEGY_B_ENABLED=true
STRATEGY_C_ENABLED=true
STRATEGY_A_UNIVERSE_TAGS=[]

# ── Alerting (optional) ───────────────────────────────────────────────────────
TELEGRAM_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
